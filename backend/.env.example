# LegalDiff Backend — Environment Variables
# Copy to .env and adjust for your deployment.

# Database
DATABASE_URL=postgresql+asyncpg://legaldiff:legaldiff_secret@localhost:5432/legaldiff
DATABASE_URL_SYNC=postgresql://legaldiff:legaldiff_secret@localhost:5432/legaldiff

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Server (llama.cpp)
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# Storage
STORAGE_ROOT=./backend/storage

# Logging
LOG_LEVEL=INFO
